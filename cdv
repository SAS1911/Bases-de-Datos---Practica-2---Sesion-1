package cursos;

import java.io.*;
import java.sql.*;
import java.time.LocalDate;

public class InsertaImparteDesdeCSV implements DataBaseTask {

    @Override
    public void run(Connection conn, String data) throws BBDDException, SQLException {
        String sql = "INSERT INTO imparte (profesor_id, curso_id, n_modulo, aula_id, fecha) VALUES (?, ?, ?, ?, ?)";

        try (BufferedReader br = new BufferedReader(new FileReader(data));
             PreparedStatement ps = conn.prepareStatement(sql)) {

            String linea;

            while ((linea = br.readLine()) != null) {
                String[] campos = linea.split(",");

                if (campos.length != 5) {
                    throw new BBDDException("Formato incorrecto en CSV");
                }

                int profesorId = Integer.parseInt(campos[0].trim());
                int cursoId = Integer.parseInt(campos[1].trim());
                int nModulo = Integer.parseInt(campos[2].trim());
                int aulaId = Integer.parseInt(campos[3].trim());
                LocalDate fecha = LocalDate.parse(campos[4].trim());

                ps.setInt(1, profesorId);
                ps.setInt(2, cursoId);
                ps.setInt(3, nModulo);
                ps.setInt(4, aulaId);
                ps.setDate(5, Date.valueOf(fecha));

                int filas = ps.executeUpdate();

                if (filas != 1) {
                    throw new SQLException("La inserción no afectó a 1 fila");
                }
            }

        } catch (IOException | RuntimeException e) {
            BBDDException ex = new BBDDException("Error procesando CSV");
            ex.setWhen("Insertando");
            throw ex;
        }
    }
}
