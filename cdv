import java.io.*;
import java.sql.*;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;

public class InsertaImparteDesdeCSV implements DataBaseTask {

@Override
    public void run(Connection conn, String data) throws BBDDException, SQLException {

   String sql = "INSERT INTO imparte (profesor_id, curso_id, n_modulo, aula_id, fecha) VALUES (?, ?, ?, ?, ?)";
        DateTimeFormatter formatter = DateTimeFormatter.ofPattern("yyyy-MM-dd");

   try (BufferedReader br = new BufferedReader(new FileReader(data));
     PreparedStatement ps = conn.prepareStatement(sql)) {

    String l;
        int numL = 0;

            while ((l = br.readLine()) != null) {
                numL++;
                try {
           String[] espacio = l.split(",");
            if (espacio.length != 5) {
            throw new BBDDException("Formato incorrecto en CSV en línea " + numL);
                    }

                    int profesorId = Integer.parseInt(espacio[0].trim());
                    int cursoId = Integer.parseInt(espacio[1].trim());
                    int nModulo = Integer.parseInt(espacio[2].trim());
                    int aulaId = Integer.parseInt(espacio[3].trim());
                    LocalDate fecha = LocalDate.parse(espacio[4].trim(), formatter);

                    ps.setInt(1, profesorId);
                    ps.setInt(2, cursoId);
                    ps.setInt(3, nModulo);
                    ps.setInt(4, aulaId);
                    ps.setDate(5, Date.valueOf(fecha));

                    int filas = ps.executeUpdate();

                    if (filas != 1) {
                        throw new SQLException("No afecta la inserccion " + numL);
                    }

                } catch (NumberFormatException e) {
                    throw new BBDDException("Error en " + numL + ": " + l);
                } catch (DateTimeParseException e) {
                    throw new BBDDException("Formato de fecha incorrecto " + numL + ": " + camposErrorSeguro(l));
                }
            }

        } catch (IOException e) {
            BBDDException ex = new BBDDException("Error con el .csv");
            ex.setWhen("Insertando");
            throw ex;
        } catch (BBDDException e) {
            e.setWhen("Insertando");
            throw e;
        }
    }

    private String camposErrorSeguro(String linea) {
        try {
            return linea.split(",")[4].trim();
        } catch (Exception e) {
            return linea;
        }
    }
}
